# =============================================================================
# Environment Variables — copy this file to .env and fill in your values
# NEVER commit .env to git (it is listed in .gitignore)
# =============================================================================

# Your wallet's private key (WITHOUT the 0x prefix is fine, Hardhat handles both)
# Get this from MetaMask → Account Details → Export Private Key
# Or from Hedera Portal: https://portal.hedera.com
#
# ⚠️  SECURITY: This key controls real funds. Keep it secret.
PRIVATE_KEY=your_private_key_here

# Optional: Hashscan API key for contract verification
# Get one at: https://hashscan.io (not required for basic deployment)
HASHSCAN_API_KEY=your_hashscan_api_key_here
